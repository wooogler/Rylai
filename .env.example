# RYLAI Environment Variables Configuration
# Copy this file to .env.local for local development
# Copy this file to .env for Docker deployment

# ============================================
# DATABASE CONFIGURATION
# ============================================
# SQLite database file path (optional, defaults to ./data/rylai.db)
DATABASE_URL=./data/rylai.db

# ============================================
# AI MODEL CONFIGURATION
# ============================================

# OpenRouter API Key (RECOMMENDED)
# Supports 13+ models: GPT-4o, Claude, Gemini, Llama, Mistral
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# OpenAI API Key (OPTIONAL)
# Only needed if you want direct OpenAI access instead of OpenRouter
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Local API Mode (OPTIONAL)
# Set to 'true' to use local Mistral-7B instead of cloud APIs
# Requires running local API server at http://localhost:8000/v1
NEXT_PUBLIC_USE_LOCAL_API=false

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Public URL for OpenRouter HTTP-Referer header (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000
